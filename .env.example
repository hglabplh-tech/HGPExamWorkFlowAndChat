DATABASE_URL=postgresql+asyncpg://study:study@localhost:5432/study
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_MINUTES=15
NONCE_TTL_SECONDS=3600
SIGNATURE_CLOCK_SKEW_SECONDS=300
CHROMA_URL=http://localhost:8001
PUBLIC_BASE_URL=https://localhost
RETENTION_YEARS=10
EMBEDDING_PROFILE=economy
COMPUTE_DEVICE=auto
# Required for eIDAS AdES/Trusted List v6 validation (EU DSS 6.2+ service):
EU_DSS_VALIDATOR_URL=
# HSM/KMS-backed RFC 6960 response signer for customer private PKIs:
OCSP_SIGNER_URL=
OCSP_SIGNER_TOKEN=replace-with-a-separate-random-service-token
NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
GENERATION_MODEL=google/flan-t5-base
NIGHTLY_TRAINING_MODE=dataset
MODEL_OUTPUT_DIR=/tmp/study-models
MINIMUM_TRAINING_EXAMPLES=20
TRAINING_INTERVAL_HOURS=48
TRAINING_EPOCHS=3
TRAINING_LEARNING_RATE=0.00002
TRAINING_WEIGHT_DECAY=0.01
TRAINING_DROPOUT=0.25
TRAINING_LABEL_SMOOTHING=0.1
TRAINING_BATCH_SIZE=8
TRAINING_SEED=42
TRAINING_THREAD_WORKERS=2
SUBMISSION_CORRECTION_MINUTES=15
UPLOAD_MAX_BYTES=26214400
PDF_MAX_PAGES=500
AUDIO_MODEL=openai/whisper-tiny
AUDIO_MAX_SECONDS=600
INFERENCE_TIMEOUT_SECONDS=120
PASSWORD_AUTH_ENABLED=true
CLIENT_CERTIFICATE_AUTH_ENABLED=true
SIGNATURE_HASH_ALGORITHM=SHA-256
SIGNATURE_ALGORITHMS=Ed25519,ECDSA-SHA256,RSA-PSS-SHA256
CERTIFICATE_DEFAULT_VALID_DAYS=365
WEB_CONCURRENCY=2
KEEP_ALIVE_TIMEOUT_SECONDS=10
TRAINING_EARLY_STOPPING_PATIENCE=2
TRAINING_EARLY_STOPPING_MIN_DELTA=0.0001
INTERNET_SEARCH_ENDPOINT=
INTERNET_SEARCH_API_KEY=
INTERNET_SEARCH_TIMEOUT_SECONDS=20
GRAMMAR_SERVICE_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
EMAIL_FROM=no-reply@example.invalid
SUPPORT_EMAIL=
